# Upstream LLM API URL to proxy requests to (Required)
PROXY_TARGET_URL=https://api.openai.com

# Port the proxy server will listen on
PROXY_PORT=8318

# Rate limiting configuration (Set to 0 to disable)
RATE_LIMIT_RPM=20
RATE_LIMIT_BURST=5

# SQLite database file path for storing API logs
PROXY_LOGS_DB=proxy_logs.db

# Dynamic Model Replacements
# Can be a comma-separated list of "old-model:new-model" or a JSON map.
# MODEL_REPLACE="GEMINI:gemini-flash,chatgpt:gpt-4o"

# Dynamic API Key Replacements
# Can be a comma-separated list of "client-key:upstream-key" or a JSON map.
# API_KEY_REPLACE="client-key-1:upstream-key-1,client-key-2:upstream-key-2"

# Injected Headers (HEADER_<NAME>). Single underscores are replaced with hyphens.
# HEADER_User_Agent="my-custom-client/1.0"
# HEADER_X_Client_Version="1.0.0"

# Alternatively, a JSON map for injecting headers
# INJECT_HEADERS_JSON='{"User-Agent": "my-custom-client/1.0"}'
